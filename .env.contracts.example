# Aleo Smart Contract Configuration
# Add these to your .env.local after deploying the contracts

# Main credential and attestation program
NEXT_PUBLIC_SHADOWID_PROGRAM_ID=shadowid_v2

# Credential registry program
NEXT_PUBLIC_CREDENTIAL_REGISTRY_PROGRAM_ID=credential_registry

# QR verifier program
NEXT_PUBLIC_QR_VERIFIER_PROGRAM_ID=qr_verifier

# Aleo network
NEXT_PUBLIC_ALEO_NETWORK=testnet

# Encryption key (generate a strong random string)
ALEO_ENCRYPTION_SALT=your_encryption_salt_here
